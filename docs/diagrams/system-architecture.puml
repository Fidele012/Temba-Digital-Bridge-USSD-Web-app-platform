@startuml System Architecture — Temba Digital Bridge
top to bottom direction

skinparam backgroundColor #FAFCFF
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 11
skinparam shadowing false
skinparam arrowThickness 2
skinparam RoundCorner 10
skinparam Nodesep 25
skinparam Ranksep 30

skinparam package {
    BackgroundColor #F8FAFC
    BorderColor #94A3B8
    BorderThickness 2
    FontStyle bold
    FontSize 13
    FontColor #0F172A
}

skinparam rectangle {
    RoundCorner 10
    FontSize 11
}

' ══════════════════════════════════════════════════════════
' PHASE 1 — USER ENTRY
' ══════════════════════════════════════════════════════════
package "1.  USER ENTRY — Registration" as P1 #EFF6FF {
    rectangle "🌐  **Web Registration**\nEmail · Password · Location\nProvince → District" as WEB_REG #1E40AF;text:white
    rectangle "📱  **USSD Registration**\nDial *384*36640#\nName · Province · District · PIN" as USSD_REG #1E40AF;text:white
    rectangle "🏢  **Provider Registration**\nOrganisation · SLA Commitment\nOfficer & Supervisor Contacts" as PROV_REG #0F766E;text:white
}

rectangle "📧  **Email Verification**\nGmail SMTP · OTP Code" as VERIFY_EMAIL #B45309;text:white
rectangle "🔍  **Admin Review**\n(Providers Only)\ntembadigitalbridge@gmail.com" as ADMIN_REVIEW #6D28D9;text:white

' ══════════════════════════════════════════════════════════
' PHASE 2 — AUTHENTICATION
' ══════════════════════════════════════════════════════════
package "2.  AUTHENTICATION" as P2 #F0FDFA {
    rectangle "🔐  **Web Login**\nJWT HS256 · bcrypt\n15-min Access Token\n7-day Refresh in Redis" as WEB_LOGIN #0F766E;text:white
    rectangle "📱  **USSD Login**\n4-Digit PIN\nPhone Number Lookup" as USSD_LOGIN #0F766E;text:white
    rectangle "🔒  **NGINX Load Balancer**\nSSL/TLS · Rate Limiting\nAPI Gateway" as NGINX #0F766E;text:white
}

' ══════════════════════════════════════════════════════════
' PHASE 3 — COMMUNITY MEMBER ACTIONS
' ══════════════════════════════════════════════════════════
package "3.  COMMUNITY MEMBER ACTIONS — FastAPI :8000" as P3 #EEF2FF {
    rectangle "🚰  **Report Water Issue**\nCategory · Urgency · Location\nPhoto Upload · Provider Selection" as REPORT #4F46E5;text:white
    rectangle "📋  **Submit Service Request**\nNew Connection · Tank Delivery\nMeter Support · Inspection" as SVC_REQ #4F46E5;text:white
    rectangle "📅  **Book Appointment**\nReason · Date · Time\nProvider Selection" as APPT #4F46E5;text:white
    rectangle "🔍  **Track Issue**\nReference Code (RPT-YYYYMMDD-XXXX)\nNo Login Required" as TRACK #4F46E5;text:white
}

rectangle "🏷️  **Auto Priority Classification**\n🔴 P1 Critical (4h SLA)\n🟠 P2 Urgent (24h SLA)\n🔵 P3 Standard (72h SLA)" as PRIORITY #1E40AF;text:white

' ══════════════════════════════════════════════════════════
' PHASE 4 — PROVIDER PROCESSING
' ══════════════════════════════════════════════════════════
package "4.  WATER SERVICE PROVIDER — Dashboard" as P4 #FFF7ED {
    rectangle "📥  **Receive Report**\nIn-App Notification\nSMS Alert to Officer" as RECEIVE #92400E;text:white
    rectangle "✅  **Acknowledge**\nfirst_responded_at = NOW\nStatus → ACKNOWLEDGED" as ACK #92400E;text:white
    rectangle "🔧  **Work on Issue**\nStatus → IN_PROGRESS\nUpdate Notes for Community" as WORK #92400E;text:white
    rectangle "📤  **Submit Resolution**\nResolution Notes\nStatus → RESOLUTION_SUBMITTED" as RESOLVE #92400E;text:white
}

' ══════════════════════════════════════════════════════════
' PHASE 5 — SLA & ACCOUNTABILITY ENGINE
' ══════════════════════════════════════════════════════════
package "5.  SLA & ACCOUNTABILITY ENGINE — Celery" as P5 #FAF5FF {
    rectangle "⏱️  **SLA Monitor**\nCelery Beat · Hourly Check\noverdue_flagged = true" as SLA_MON #6D28D9;text:white
    rectangle "👤  **Level 1 → Officer**\nEmail + SMS Alert\n(0h overdue)" as ESC_L1 #6D28D9;text:white
    rectangle "👔  **Level 2 → Supervisor**\nEscalation Email\n(+24h overdue)" as ESC_L2 #6D28D9;text:white
    rectangle "📜  **Audit Log**\nImmutable Record\nActor · Action · Timestamp" as AUDIT #6D28D9;text:white
}

' ══════════════════════════════════════════════════════════
' PHASE 6 — COMMUNITY VERIFICATION & RATING
' ══════════════════════════════════════════════════════════
package "6.  COMMUNITY VERIFICATION & FEEDBACK" as P6 #F0FDF4 {
    rectangle "✅  **Verify Resolution**\nConfirmed Fixed → VERIFIED\nDisputed → FOLLOW_UP\nNo Response (7d) → AUTO_CLOSED" as VERIFY #166534;text:white
    rectangle "⭐  **Anonymous Rating**\n1-5 Stars · Optional Comment\nNo user_id Stored\nProvider Sees Aggregate Only" as RATE #166534;text:white
}

' ══════════════════════════════════════════════════════════
' PHASE 7 — DATA & EXTERNAL SERVICES
' ══════════════════════════════════════════════════════════
package "7.  DATA & EXTERNAL SERVICES" as P7 #F1F5F9 {
    database "🐘  **PostgreSQL 16**\nUsers · Reports · Requests\nProviders · Ratings · Audit" as PG #075985;text:white
    database "⚡  **Redis 7**\nJWT Tokens · OTP Codes\nCelery Task Queue" as REDIS #075985;text:white
    rectangle "🗄️  **MinIO S3**\nReport Photos\nDocuments" as MINIO #075985;text:white
    rectangle "📞  **Africa's Talking**\nUSSD Gateway\nSMS Delivery" as AT #92400E;text:white
    rectangle "📧  **Gmail SMTP**\nVerification · Reset\nEscalation Emails" as SMTP #92400E;text:white
}

' ══════════════════════════════════════════════════════════
' FLOW — Sequential User Journey
' ══════════════════════════════════════════════════════════

' Phase 1 → Verification
WEB_REG -[#1D4ED8,bold]down-> VERIFY_EMAIL : "  Verify email  "
USSD_REG -[#1D4ED8,bold]down-> USSD_LOGIN : "  PIN created  "
PROV_REG -[#0F766E,bold]down-> ADMIN_REVIEW : "  Status: PENDING  "
ADMIN_REVIEW -[#6D28D9,bold]down-> WEB_LOGIN : "  APPROVED  "

' Phase 1 → Phase 2
VERIFY_EMAIL -[#1D4ED8,bold]down-> WEB_LOGIN : "  Email confirmed  "

' Phase 2 → Phase 3
WEB_LOGIN -[#0F766E,bold]down-> NGINX : "  JWT Bearer  "
USSD_LOGIN -[#0F766E,bold]down-> NGINX : "  PIN verified  "
NGINX -[#4338CA,bold]down-> REPORT : "  Routed requests  "
NGINX -[#4338CA,bold]down-> SVC_REQ
NGINX -[#4338CA,bold]down-> APPT

' Phase 3 → Priority
REPORT -[#1E40AF,bold]down-> PRIORITY
SVC_REQ -[#1E40AF,bold]down-> PRIORITY
APPT -[#1E40AF,bold]down-> PRIORITY

' Phase 3 → Phase 4
PRIORITY -[#B45309,bold]down-> RECEIVE : "  Assigned to provider  "

' Phase 4 sequential flow
RECEIVE -[#B45309,bold]down-> ACK
ACK -[#B45309,bold]down-> WORK
WORK -[#B45309,bold]down-> RESOLVE

' Phase 4 → Phase 5 (SLA runs in parallel)
RECEIVE -[#7C3AED,bold]right-> SLA_MON : "  SLA deadline\n  starts  "
SLA_MON -[#7C3AED,bold]down-> ESC_L1 : "  Deadline missed  "
ESC_L1 -[#7C3AED,bold]down-> ESC_L2 : "  +24h no response  "
ESC_L2 -[#7C3AED,bold]down-> AUDIT

' Phase 4 → Phase 6
RESOLVE -[#166534,bold]down-> VERIFY : "  Community notified  "
VERIFY -[#166534,bold]right-> RATE : "  If verified  "

' Phase 6 → back to Phase 4 (dispute loop)
VERIFY -[#C62828,bold]left-> WORK : "  Disputed →\n  Reopened  "

' Phase 7 connections (data layer supports everything)
NGINX -[#0369A1,dashed]down-> PG
NGINX -[#0369A1,dashed]down-> REDIS
REPORT -[#0369A1,dashed]down-> MINIO : "  Photos  "
SLA_MON -[#B45309,dashed]down-> AT : "  SMS alerts  "
SLA_MON -[#B45309,dashed]down-> SMTP : "  Escalation\n  emails  "

' Hidden ordering
P1 -[hidden]down-> P2
P2 -[hidden]down-> P3
P3 -[hidden]down-> P4
P4 -[hidden]down-> P5
P5 -[hidden]down-> P6
P6 -[hidden]down-> P7

' ══════════════════════════════════════════════════════════
' LEGEND
' ══════════════════════════════════════════════════════════
legend right
  | **Arrow** | **Flow** |
  |<#1D4ED8>  | User registration |
  |<#0F766E>  | Authentication |
  |<#4338CA>  | Request routing |
  |<#1E40AF>  | Priority classification |
  |<#B45309>  | Provider processing |
  |<#7C3AED>  | SLA / Escalation |
  |<#166534>  | Verification & Rating |
  |<#C62828>  | Dispute (loop back) |
  |<#0369A1>  | Data persistence (dashed) |
endlegend

@enduml
