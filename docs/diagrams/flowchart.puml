@startuml Report Lifecycle & Accountability Loop — Temba Digital Bridge

skinparam backgroundColor #FAFCFF
skinparam ActivityBackgroundColor #EFF6FF
skinparam ActivityBorderColor #1D4ED8
skinparam ActivityDiamondBackgroundColor #FEF3C7
skinparam ActivityDiamondBorderColor #B45309
skinparam ArrowColor #475569
skinparam defaultFontName "Segoe UI"
skinparam shadowing false

|Community Member|
start
:🏁 **Submit Report**;
:📝 Fill Report Form
  Category · Urgency · Description
  Location (Province → Village)
  Optional Photo Upload;
:POST /api/v1/reports;

|System|
:🔖 Generate Reference Number
  RPT-YYYYMMDD-XXXX;
:⏱ Calculate SLA Deadline
  ── Contamination & Pipe Burst → 4 h
  ── No Supply → 24 h
  ── Other Issues → 72 h;
:📲 Notify Provider
  In-App Notification + SMS;

if (Provider Acknowledges?) then (Within SLA ✓)
    :Status: **ACKNOWLEDGED**
    first_responded_at = NOW;
else (SLA Breached ✗)
    :🔔 Celery SLA Checker
    Runs Hourly;
    fork
        :Notify Officer
        (Level 1 — 0 h overdue);
    fork again
        :Notify Supervisor
        (Level 2 — +24 h);
    fork again
        :Notify Regional Manager
        (Level 3 — +48 h);
    fork again
        :Notify Executive
        (Level 4 — +72 h);
    end fork
    :Status: **ACKNOWLEDGED**;
endif

|Water Service Provider|
:Status: **IN_PROGRESS**
  Provider Works on Issue;
:Provider Submits Resolution
  Status: **RESOLUTION_SUBMITTED**
  resolution_submitted_at = NOW;

|System|
:📲 Notify Community Member
  "Please Verify Resolution";

|Community Member|
if (Community Verifies?) then (Confirms Fixed ✅)
    :✅ Status: **VERIFIED**
    verified_at = NOW
    Case Closed;
elseif (No Response — 7 days) then
    :⏰ Status: **CLOSED_UNVERIFIED**
    Auto-Closed;
else (Disputes ❌)
    :❌ Status: **FOLLOW_UP_REQUIRED**
    reopen_count++;
    if (reopen_count > 2?) then (Yes)
        :Status: **MANAGEMENT_REVIEW**
        Escalate to Executive;
    else (No)
        :Resume **IN_PROGRESS**;
        note right
            Returns to Provider
            for further action
        end note
    endif
endif

|System|
:📋 Write to Audit Log
  Immutable — Never Deleted;
stop

@enduml
