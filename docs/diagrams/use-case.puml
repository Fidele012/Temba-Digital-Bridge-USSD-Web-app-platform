@startuml Use Case Diagram — Temba Digital Bridge
left to right direction

skinparam backgroundColor #FAFCFF
skinparam actorStyle awesome
skinparam packageStyle rectangle
skinparam usecaseBackgroundColor #EFF6FF
skinparam usecaseBorderColor #1D4ED8
skinparam usecaseFontSize 11
skinparam rectangleBackgroundColor #F8FAFC
skinparam rectangleBorderColor #475569
skinparam rectangleFontSize 13
skinparam rectangleFontStyle bold
skinparam packageBackgroundColor #F1F5F9
skinparam packageBorderColor #94A3B8
skinparam arrowColor #475569
skinparam defaultFontName "Segoe UI"

actor "Community Member\n(Web)" as CM #1E40AF
actor "Feature Phone User\n(USSD)" as FPU #1E40AF
actor "Provider Staff" as PS #0F766E
actor "Africa's Talking\n<<External System>>" as AT #92400E

rectangle "**Temba Digital Bridge — System Boundary**" {

    package "Authentication" {
        usecase "Register Account" as UC_REG
        usecase "Login / Authenticate" as UC_LOGIN
        usecase "Forgot Password" as UC_FORGOT
        usecase "Verify Email" as UC_VERIFY
    }

    package "Community Actions" {
        usecase "Submit Water Issue Report" as UC_REPORT
        usecase "Track Report by\nReference Code" as UC_TRACK
        usecase "Verify Provider\nResolution" as UC_VERIFY_RES
        usecase "Book Appointment" as UC_BOOK
        usecase "Request Reschedule" as UC_RESCHED
        usecase "Cancel Appointment" as UC_CANCEL_APPT
        usecase "Submit Service Request" as UC_SREQ
        usecase "Browse Service\nProviders" as UC_BROWSE
        usecase "View Notifications" as UC_NOTIF
        usecase "Switch Language\nEN / KN" as UC_LANG
    }

    package "USSD Channel" {
        usecase "Register via USSD" as UC_USSD_REG
        usecase "Report Issue\nvia USSD" as UC_USSD_REP
        usecase "Track Status\nvia USSD" as UC_USSD_TRACK
        usecase "Receive SMS\nConfirmation" as UC_SMS
    }

    package "Provider Actions" {
        usecase "Manage Reports" as UC_MREPORTS
        usecase "Update Report Status" as UC_USTATUS
        usecase "Submit Resolution" as UC_SUBMIT_RES
        usecase "Manage Appointments" as UC_MAPPT
        usecase "Propose New Time" as UC_PROPOSE
        usecase "Manage Service\nRequests" as UC_MSR
        usecase "Set Availability\nSchedule" as UC_AVAIL
        usecase "Manage Team Members" as UC_TEAM
        usecase "View Stats &\nSLA Dashboard" as UC_STATS
    }

    package "System Services" {
        usecase "Send SMS Notification" as SVC_SMS
        usecase "Send Email" as SVC_EMAIL
        usecase "Check SLA &\nEscalate" as SVC_SLA
    }
}

' ── Community Member ─────────────────────────────────
CM --> UC_REG
CM --> UC_LOGIN
CM --> UC_FORGOT
CM --> UC_REPORT
CM --> UC_TRACK
CM --> UC_VERIFY_RES
CM --> UC_BOOK
CM --> UC_RESCHED
CM --> UC_CANCEL_APPT
CM --> UC_SREQ
CM --> UC_BROWSE
CM --> UC_NOTIF
CM --> UC_LANG

' ── Feature Phone User ───────────────────────────────
FPU --> UC_USSD_REG
FPU --> UC_USSD_REP
FPU --> UC_USSD_TRACK

' ── Africa's Talking (external gateway) ──────────────
AT -- UC_USSD_REG
AT -- UC_USSD_REP
AT -- UC_USSD_TRACK

' ── Provider Staff ───────────────────────────────────
PS --> UC_LOGIN
PS --> UC_MREPORTS
PS --> UC_MAPPT
PS --> UC_MSR
PS --> UC_AVAIL
PS --> UC_TEAM
PS --> UC_STATS

' ── <<include>> relationships ────────────────────────
UC_REG .right.> SVC_EMAIL : <<include>>
UC_REG .down.> UC_VERIFY : <<include>>
UC_REPORT ..> SVC_SMS : <<include>>
UC_VERIFY_RES ..> SVC_SMS : <<include>>
UC_USTATUS ..> SVC_SMS : <<include>>
UC_MAPPT ..> SVC_SMS : <<include>>
UC_MREPORTS ..> UC_USTATUS : <<include>>
UC_MREPORTS ..> SVC_SLA : <<include>>
UC_MAPPT ..> UC_PROPOSE : <<include>>
UC_USTATUS ..> UC_SUBMIT_RES : <<include>>
UC_USSD_REP ..> UC_SMS : <<include>>

' ── <<extend>> relationships ─────────────────────────
UC_BOOK ..> UC_RESCHED : <<extend>>
UC_REPORT ..> UC_USSD_REP : <<extend>>

@enduml
